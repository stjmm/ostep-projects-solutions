 }
 
+int
+mprotect(void *addr, int len)
+{
+  struct proc *curproc = myproc();
+  if ((uint)addr + len * PGSIZE > curproc->sz)
+    return -1;
+
+  pte_t *pte;
+  for (uint a = (uint)addr; a < (uint)addr + len * PGSIZE; a += PGSIZE) {
+      pte = walkpgdir(curproc->pgdir, (char*)a, 0);
+      if (!pte || !(*pte & PTE_P))
+        return -1;
+
+      *pte &= ~PTE_W;
+  }
+  
+  lcr3(V2P(curproc->pgdir));
+
+  return 0;
+}
+
+int
+munprotect(void *addr, int len)
+{
+  struct proc *curproc = myproc();
+  if ((uint)addr + len * PGSIZE > curproc->sz)
+    return -1;
+
+  pte_t *pte;
+  for (uint a = (uint)addr; a < (uint)addr + len * PGSIZE; a += PGSIZE) {
+      pte = walkpgdir(curproc->pgdir, (char*)a, 0);
+      if (!pte || !(*pte & PTE_P))
+        return -1;
+
+      *pte |= PTE_W;
+  }
+  
+  lcr3(V2P(curproc->pgdir));
+
+  return 0;
+}
