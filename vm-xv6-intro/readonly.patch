@@ -89,3 +89,31 @@
   release(&tickslock);
   return xticks;
 }
+
+int
+sys_mprotect(void)
+{
+  void *addr;
+  int len;
+
+  if (argptr(0, (char **)&addr, sizeof(void *)) || argint(1, &len) < 0)
+    return -1;
+  if ((uint)addr % PGSIZE != 0 || len <= 0 || (uint)addr < PGSIZE)
+    return -1;
+  
+  return mprotect(addr, len);
+}
+
+int
+sys_munprotect(void)
+{
+  void *addr;
+  int len;
+
+  if (argptr(0, (char **)&addr, sizeof(void *)) < 0 || argint(1, &len) < 0)
+    return -1;
+  if ((uint)addr % PGSIZE != 0 || len <= 0 || (uint)addr < PGSIZE)
+    return -1;
+  
+  return munprotect(addr, len);
+}
diff '--color=auto' -uN xv6-public/test_readonly.c src2/test_readonly.c
--- xv6-public/test_readonly.c	1970-01-01 01:00:00.000000000 +0100
+++ src2/test_readonly.c	2026-04-10 10:21:29.620595857 +0200
@@ -0,0 +1,45 @@
+#include "types.h"
+#include "user.h"
+
+#define PGSIZE 4096
+
+int main(void) {
+  // 1. Setup aligned memory
+  char *mem = sbrk(PGSIZE * 2);
+  char *p = (char *)((((uint)mem) + PGSIZE - 1) & ~(PGSIZE - 1));
+  
+  *p = 'A'; // Initial write should work fine
+
+  // 2. Protect in the Parent
+  if (mprotect(p, 1) < 0) {
+    printf(1, "mprotect failed\n");
+    exit();
+  }
+  printf(1, "Parent: Protected page at %p\n", p);
+
+  // 3. Fork
+  int pid = fork();
+
+  if (pid < 0) {
+    printf(1, "fork failed\n");
+    exit();
+  }
+
+  if (pid == 0) {
+    // CHILD PROCESS
+    printf(1, "Child: Inherited page. Attempting write (Should trap)...\n");
+    *p = 'B'; 
+    printf(1, "FAIL: Child survived writing to protected page!\n");
+    exit();
+  } else {
+    // PARENT PROCESS
+    wait(); // Wait for child to get killed
+    printf(1, "Parent: Child process finished (likely killed by trap).\n");
+    
+    printf(1, "Parent: Attempting write to own page (Should also trap)...\n");
+    *p = 'C';
+    printf(1, "FAIL: Parent survived writing to protected page!\n");
+  }
+
+  exit();
+}
