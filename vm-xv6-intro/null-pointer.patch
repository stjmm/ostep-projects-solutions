diff '--color=auto' -uN xv6-public/check_null.c src/check_null.c
--- xv6-public/check_null.c	1970-01-01 01:00:00.000000000 +0100
+++ src/check_null.c	2026-04-10 09:22:05.288793575 +0200
@@ -0,0 +1,16 @@
+#include "types.h"
+#include "user.h"
+
+// Before we apply our patch if we run this program it will print addresses of the .text section which starts at 0
+// After we apply the patch if we run this program we get a trap error and the process will be killed
+int main(int argc, char **argv)
+{
+    char *p = 0;
+    int i;
+
+    printf(1, "Reading memory at address 0:\n");
+    for (i = 0; i < 20; i++)
+        printf(1, "Byte %d: 0x%x\n", p[i]);
+
+    exit();
+}
